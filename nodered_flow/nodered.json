        "func": "let tempThreshold = flow.get(\"tempThreshold\") || 30;\nlet distanceThreshold = flow.get(\"distanceThreshold\") || 10;\n\nlet alert = null;\n\n// Temperature alert\nif (msg.topic === \"sensors/temperature\" && msg.payload.value > tempThreshold) {\n    alert = \"🔥 HIGH TEMPERATURE!\";\n}\n\n// Motion alert\nif (msg.topic === \"sensors/motion\" && msg.payload.detected == 1) {\n    alert = \"🚨 MOTION DETECTED!\";\n}\n\n// Distance alert\nif (msg.topic === \"sensors/distance\" && msg.payload.value < distanceThreshold) {\n    alert = \"⚠ OBJECT TOO CLOSE!\";\n}\n\nif(!alert){\n    return null;\n}\n\n// -------- UI ALERT --------\n\nlet uiMsg = {\n    payload: alert\n};\n\n// -------- ALERT LOG --------\n\nlet history = flow.get(\"alertHistory\") || [];\n\nlet entry = {\n    timestamp: new Date().toLocaleString(),\n    alert: alert,\n    sensor: msg.topic\n};\n\nhistory.unshift(entry);\n\nif(history.length > 50){\n    history.pop();\n}\n\nflow.set(\"alertHistory\", history);\n\nlet logMsg = {\n    payload: history\n};\n\n// -------- EMAIL COOLDOWN --------\n\nlet lastSent = flow.get(\"lastAlertTime\") || 0;\nlet now = Date.now();\nlet cooldown = 300000; // 5 minutes\n\nlet emailMsg = null;\n\nif(now - lastSent > cooldown){\n    flow.set(\"lastAlertTime\", now);\n    emailMsg = { payload: alert };\n}\n\n// return to 3 outputs\nreturn [uiMsg, emailMsg, logMsg];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
