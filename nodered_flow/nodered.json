    {
        "id": "89b85a45cce03e81",
        "type": "function",
        "z": "39d8ba27391e7293",
        "name": "Sensor Router",
        "func": "let topic = msg.topic;\n\nswitch(topic) {\n\n    case \"sensors/temperature\":\n        msg.topic = \"temperature\";\n        msg.payload = msg.payload.value;\n        return [msg, null, null, null, null];\n\n    case \"sensors/humidity\":\n        msg.topic = \"humidity\";\n        msg.payload = msg.payload.value;\n        return [null, msg, null, null, null];\n\n    case \"sensors/light\":\n        msg.topic = \"light\";\n        msg.payload = msg.payload.value;\n        return [null, null, msg, null, null];\n    \n    case \"sensors/distance\":\n        msg.topic = \"distance\";\n        msg.payload = msg.payload.value;\n        return [null, null, null, msg, null];\n\n    case \"sensors/motion\":\n        msg.topic = \"motion\";\n        msg.payload = msg.payload.detected ? \"Motion Detected\" : \"No Motion\";\n        return [null, null, null, null, msg];\n\n    default:\n        return null;\n}",
        "outputs": 5,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
