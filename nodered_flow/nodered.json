        "z": "39d8ba27391e7293",
        "name": "format table",
        "func": "// allowed sensor topics\nlet allowed = [\n    \"sensors/temperature\",\n    \"sensors/humidity\",\n    \"sensors/light\",\n    \"sensors/distance\",\n    \"sensors/motion\"\n];\n\n// ignore anything else\nif(!allowed.includes(msg.topic)){\n    return null;\n}\n\nlet logs = flow.get(\"sensorLogs\") || [];\n\nlet entry = {\n    timestamp: new Date().toLocaleString(),\n    sensor: msg.topic,\n    value: msg.payload.value ?? msg.payload.detected\n};\n\nlogs.unshift(entry);\n\n// keep last 50 rows\nif(logs.length > 50){\n    logs.pop();\n}\n\nflow.set(\"sensorLogs\", logs);\n\nmsg.payload = logs;\n\nreturn msg;",
